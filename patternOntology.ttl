@prefix : <http://example.org/security#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .



# Klases
:Pattern a owl:Class .

:AttackDetection a owl:Class ;
    rdfs:subClassOf :Pattern .

:AttackPrevention a owl:Class ;
    rdfs:subClassOf :Pattern .



# Atribūtu piešķiršana AttackDetection klasei
:name rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:attackType rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:attackCharecharistics rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:impactedSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .



# Atribūtu piesķiršana AttackPrevention klasei
:name rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:problem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:goal rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:impactedSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:limitations rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:steps rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:commands rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .



# DOS šablonu instanču izveidošana
:endPointDenialOfService a :AttackDetection ;
    :name "Pakalpojumatteices uzbrukums" ; #sarunvaloda
    :attackType "Sistēmas ietekmes" ; #sarunvaloda
    :attackCharacteristics "Tiek veikta nepārtraukta pieprasījumu izsūtīšana, kas patērē servera resursus, palēlinot vai apturot tā darbību." ; # aparaksts par sistemas uzbrukuma darbibu
    :impactedSystem "Pieprasījuma apstrāde". # ipv4 adrese

:inboundTrafficFiltering a :AttackPrevention ;
    :name "Ienākošās datplūsmas filtrēšana" ; #sarunvaloda
    :problem "Pakalpojumatteices uzbrukums" ; #sarunvaloda
    :goal "Filtrēt ienākošo datplūsmu pēc adresēm, kur izolē sistēmu no ļaunprātīgās datplūsmas izcelsmes adreses." ; #sarunvaloda
    :impactedSystem "Pieprasījuma apstrāde" ; # ipv4 adrese
    :limitations "Nav efektīvs, ja uzbrukums tiek veikts no dažādām ip adresēm vienlaikus." ; #
    :steps "Ar bash kommandu aizliedz sistēmai pieņemt jebkādus pieprasījumus no konkrētās ip adreses." ; #aprakstiti soli
    :commands "ufw deny from <var> to any" . #koda aprakstiti soli

# Datu manipulācijas šablonu instanču izveidošana
:dataManipulation a :AttackDetection ;
    :name "Datu manipulācija" ; #sarunvaloda
    :attackType "Sistēmas ietekmes" ; #sarunvaloda
    :attackCharacteristics "Tiek veikts mēģinājums neatļauti ievietot, izdzēst vai mainīt datus sistēmā." ; # aparaksts par sistemas uzbrukuma darbibu
    :impactedSystem "Failu krātuve". # ipv4 adrese

:restrictFilePremissions a :AttackPrevention ;
    :name "Ierobežot tiesibas failu maiņai" ; #sarunvaloda VISIEM NEADMINIEM BLOKE MAPI
    :problem "Datu manipulācija" ; #sarunvaloda
    :goal "Novērst neautorizēti lietotāju spēju apstrādāt failus" ; #sarunvaloda
    :impactedSystem "Failu krātuve" ; # ipv4 adrese
    :limitations "Spēj vienlaicīgi ierobežot tikai 1 mapes piekluves un apstrādes tiesības" ; #
    :steps "Aizliedz konkrētajai mapei veikt izmaiņas tiem lietotājiem, kam nav administratora tiesību" ; #aprakstiti soli
    :commands "chmod 755 -R <var>" . #koda aprakstiti soli

# Satura injekcijas šablonu instanču izveidošana
:contentInjection a :AttackDetection ;
    :name "Satura injekcija" ; #sarunvaloda
    :attackType "Sākotnējās piekļuves" ; #sarunvaloda
    :attackCharacteristics "Uzbrucēji meģina injecēt sistēmu ar ļaunprātīgu programmatūru." ; # aparaksts par sistemas uzbrukuma darbibu
    :impactedSystem "Visa sitēma". # ipv4 adrese

:restrictWebBasedContent a :AttackPrevention ;
    :name "Tīmeklī balstīta satura ierobežošana" ; #sarunvaloda
    :problem "Satura injekcija" ; #sarunvaloda
    :goal "Neatļaut palaist vai ievietot izpildes failus, kas var ietekmēt sistēmu vai nepazīstamos failu tipus." ; #sarunvaloda
    :impactedSystem "Visa sitēma" ; # ipv4 adrese
    :limitations "Nevar atpazīt visus kaitīgos failu tipus." ; #
    :steps "Aizliedz lietotājiem, kam nav administratora tiesību, izmantot wget rīku" ; #aprakstiti soli
    :commands "chmod 750 /usr/bin/wget" . #koda aprakstiti soli



# Novērsanas saistību īpašības nodefinēšana
:PreventedBy rdf:type owl:ObjectProperty .



# Sablonu sasvstarpējo saistību definēsana
:endPointDenialOfService :PreventedBy :inboundTrafficFiltering .

:dataManipulation :PreventedBy :restrictFilePremissions .

:contentInjection :PreventedBy :restrictWebBasedContent .