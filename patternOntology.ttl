@prefix : <http://example.org/security#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .



# Klases
:Pattern a owl:Class .

:AttackDetection a owl:Class ;
    rdfs:subClassOf :Pattern .

:AttackPrevention a owl:Class ;
    rdfs:subClassOf :Pattern .



# Atribūtu piešķiršana AttackDetection klasei
:name rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:attackType rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:attackCharecharistics rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .

:impactedSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackDetection ;
    rdfs:range xsd:string .



# Atribūtu piesķiršana AttackPrevention klasei
:name rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:problem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:goal rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:operatingSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:impactedSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:limitations rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:steps rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .

:commands rdf:type owl:DatatypeProperty ;
    rdfs:domain :AttackPrevention ;
    rdfs:range xsd:string .



# DOS šablonu instanču izveidošana
:endPointDenialOfService a :AttackDetection ;
    :name "Galapunkta pakalpojumatteices uzbrukums" ; # Nosaukums
    :attackType "Sistēmas ietekmes" ; # Uzbrukuma veids
    :attackCharacteristics "Tiek veikta nepārtraukta pieprasījumu izsūtīšana, kas patērē servera resursus, palēninot vai apturot tā darbību" ; # Uzbrukuma īpašības
    :impactedSystem "Pieprasījuma apstrāde" . # Ietekmētā sistēmas daļa

:inboundTrafficFiltering a :AttackPrevention ;
    :name "Ienākošās datplūsmas filtrēšana" ;
    :problem "Pakalpojumatteices uzbrukums" ;
    :goal "Filtrēt ienākošo datplūsmu pēc adresēm, kur izolē sistēmu no ļaunprātīgās datplūsmas izcelsmes adreses" ;
    :operatingSystem "Ubuntu" ;
    :impactedSystem "Pieprasījuma apstrāde" ;
    :limitations "Nav efektīvs, ja uzbrukums tiek veikts no dažādām IP adresēm vienlaikus. Komandas atribūtā ir nepiciešams norādīt IP adresi, no kuras tiek veikta uzbrukuma pakešu izsūtīšana." ;
    :steps "Ar Bash komandu aizliedz sistēmai pieņemt jebkādus pieprasījumus no konkrētās IP adreses" ;
    :commands "ufw deny from <var> to any" .

# Datu manipulācijas šablonu instanču izveidošana
:dataManipulation a :AttackDetection ;
    :name "Datu manipulācija" ;
    :attackType "Sistēmas ietekmes" ;
    :attackCharacteristics "Tiek veikts mēģinājums neatļauti ievietot, izdzēst vai mainīt datus sistēmā" ;
    :impactedSystem "Failu krātuve" .

:restrictFilePremissions a :AttackPrevention ;
    :name "Failu un mapju tiesību ierobežošana" ;
    :problem "Datu manipulācija" ;
    :goal "Novērst neautorizēti lietotāju spēju apstrādāt failus" ;
    :operatingSystem "Ubuntu" ;
    :impactedSystem "Failu krātuve" ;
    :limitations "Spēj vienlaicīgi ierobežot tikai 1 mapes piekļuves un apstrādes tiesības. Komandas atribūtā ir nepiciešams norādīt mapes adresi sistēmā, kurai jāierobežo tiesības" ;
    :steps "Aizliedz konkrētajai mapei veikt izmaiņas tiem lietotājiem, kam nav administratora tiesību" ;
    :commands "chmod 755 -R <var>" .

# Satura injekcijas šablonu instanču izveidošana
:contentInjection a :AttackDetection ;
    :name "Satura injekcija" ;
    :attackType "Sākotnējās piekļuves" ;
    :attackCharacteristics "Uzbrucēji mēģina injicēt sistēmu ar ļaunprātīgu programmatūru" ;
    :impactedSystem "Visa sistēma" .

:restrictWebBasedContent a :AttackPrevention ;
    :name "Tīmeklī balstīta satura ierobežošana" ;
    :problem "Satura injekcija" ;
    :goal "Neatļaut palaist vai ievietot izpildes failus, kas var ietekmēt sistēmu vai nepazīstamos failu tipus" ;
    :operatingSystem "Ubuntu" ;
    :impactedSystem "Visa sistēma" ;
    :limitations "Nevar atpazīt visus kaitīgos failu tipus" ;
    :steps "Aizliedz lietotājiem, kam nav administratora tiesību, izmantot Wget rīku" ;
    :commands "chmod 750 /usr/bin/wget" .



# Novērsanas saistību īpašības nodefinēšana
:PreventedBy rdf:type owl:ObjectProperty .



# Sablonu sasvstarpējo saistību definēsana
:endPointDenialOfService :PreventedBy :inboundTrafficFiltering .

:dataManipulation :PreventedBy :restrictFilePremissions .

:contentInjection :PreventedBy :restrictWebBasedContent .